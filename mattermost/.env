# ============================================================
# CHANGE ALL VALUES BEFORE FIRST RUN
# ============================================================

# Postgres
MM_DB_USER=mattermost
MM_DB_PASSWORD=change_me_strong_db_password

# Mattermost admin — auto-created on first boot
# DELETE these three lines after first successful startup
MM_ADMIN_EMAIL=admin@yourcompany.com
MM_ADMIN_USERNAME=admin
MM_ADMIN_PASSWORD=change_me_strong_admin_password

# Site URL — change to your domain when you get a server
MM_SITE_URL=http://localhost:8081
