# =============================================================================
#  n8n Production — Environment Variables
#  Copy this file to .env and fill in all values marked with <CHANGE_ME>
# =============================================================================

# ── Domain & SSL ─────────────────────────────────────────────────────────────
# Your domain pointing to this server (e.g. n8n.yourdomain.com)
DOMAIN_NAME=n8n.yourdomain.com

# Email used for Let's Encrypt SSL certificate registration
SSL_EMAIL=admin@yourdomain.com

# ── Timezone ──────────────────────────────────────────────────────────────────
# Full list: https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
TIMEZONE=Asia/Kolkata

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_DB=n8n
POSTGRES_USER=n8n_user
# CHANGE: Use a strong password (min 32 chars, alphanumeric)
POSTGRES_PASSWORD=<CHANGE_ME_STRONG_PASSWORD>

# ── Redis ─────────────────────────────────────────────────────────────────────
# CHANGE: Use a strong password
REDIS_PASSWORD=<CHANGE_ME_REDIS_PASSWORD>

# ── n8n Security ──────────────────────────────────────────────────────────────
# CHANGE: Generate with: openssl rand -hex 32
# CRITICAL: Back this up! Losing it means losing access to all stored credentials.
N8N_ENCRYPTION_KEY=<CHANGE_ME_32_CHAR_HEX>

# CHANGE: Generate with: openssl rand -hex 32
N8N_JWT_SECRET=<CHANGE_ME_JWT_SECRET>

# ── Traefik Dashboard Auth ────────────────────────────────────────────────────
# Generate with: htpasswd -nb admin yourpassword | sed -e 's/\$/\$\$/g'
TRAEFIK_DASHBOARD_AUTH=admin:$$apr1$$<CHANGE_ME_HTPASSWD_HASH>

# ── n8n Feature Flags ────────────────────────────────────────────────────────
# Community nodes from npm registry
N8N_COMMUNITY_PACKAGES_ENABLED=true

# Allow loading custom nodes from /home/node/.n8n/custom
N8N_CUSTOM_EXTENSIONS=/home/node/.n8n/custom

# Public API — set to true to enable REST API access
N8N_PUBLIC_API_DISABLED=false

# Execution timeout in seconds (0 = unlimited)
EXECUTIONS_TIMEOUT=3600
EXECUTIONS_TIMEOUT_MAX=7200

# Max number of executions kept in DB
EXECUTIONS_DATA_MAX_AGE=336

# ── SMTP (optional — for email notifications) ────────────────────────────────
# N8N_EMAIL_MODE=smtp
# N8N_SMTP_HOST=smtp.yourdomain.com
# N8N_SMTP_PORT=587
# N8N_SMTP_USER=noreply@yourdomain.com
# N8N_SMTP_PASS=your_smtp_password
# N8N_SMTP_SENDER=noreply@yourdomain.com
# N8N_SMTP_SSL=false

# ── External Secrets (optional) ───────────────────────────────────────────────
# N8N_EXTERNAL_SECRETS_UPDATE_INTERVAL=300
