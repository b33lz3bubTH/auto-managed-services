# =============================================================================
#  n8n Production — Environment Variables
#  Copy this file to .env and fill in all values marked with <CHANGE_ME>
# =============================================================================

# ── Domain & SSL ─────────────────────────────────────────────────────────────
# Your domain pointing to this server - use HTTPS port 443, not application port 5678
DOMAIN_NAME=https://cuddly-sniffle-4q6556ppgqwhqwjj-443.app.github.dev/

# Email used for Let's Encrypt SSL certificate registration
SSL_EMAIL=admin@yourdomain.com

# ── Protocol & Networking ──────────────────────────────────────────────────────
# Must be https to match your HTTPS domain and enable WSS (WebSocket Secure)
N8N_PROTOCOL=https

# WebSocket/Editor URLs must use https with correct domain (443 HTTPS port, not 5678)
WEBHOOK_URL=https://cuddly-sniffle-4q6556ppgqwhqwjj-443.app.github.dev/
N8N_EDITOR_BASE_URL=https://cuddly-sniffle-4q6556ppgqwhqwjj-443.app.github.dev/

# Allow trusted proxies (required if behind reverse proxy like nginx)
N8N_TRUSTED_PROXY=true

# ── Timezone ──────────────────────────────────────────────────────────────────
# Full list: https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
TIMEZONE=Asia/Kolkata

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_DB=n8n
POSTGRES_USER=n8n_user
# CHANGE: Use a strong password (min 32 chars, alphanumeric)
POSTGRES_PASSWORD=<CHANGE_ME_STRONG_PASSWORD>

# ── Redis ─────────────────────────────────────────────────────────────────────
# CHANGE: Use a strong password
REDIS_PASSWORD=<CHANGE_ME_REDIS_PASSWORD>

# ── n8n Security ──────────────────────────────────────────────────────────────
# CHANGE: Generate with: openssl rand -hex 32
# CRITICAL: Back this up! Losing it means losing access to all stored credentials.
N8N_ENCRYPTION_KEY=d3c4c1a3e7f8b9c2d5e6f7a8b9c0d1e2f3a4b5c6d7e8f9a0b1c2d3e4f5a6b7

# CHANGE: Generate with: openssl rand -hex 32
N8N_JWT_SECRET=a1b2c3d4e5f6a7b8c9d0e1f2a3b4c5d6e7f8a9b0c1d2e3f4a5b6c7d8e9f0

# ── Redis (for caching/locking - optional but recommended) ──────────────────
# Uncomment to enable Redis for multi-worker setups
# REDIS_HOST=redis
# REDIS_PORT=6379
# REDIS_PASSWORD=${REDIS_PASSWORD}

# ── n8n Feature Flags ────────────────────────────────────────────────────────
# Community nodes from npm registry
N8N_COMMUNITY_PACKAGES_ENABLED=true

# Allow loading custom nodes from /home/node/.n8n/custom
N8N_CUSTOM_EXTENSIONS=/home/node/.n8n/custom

# Public API — set to true to enable REST API access
N8N_PUBLIC_API_DISABLED=false

# Disable strict origin validation for WebSocket connections (allows connections from any origin)
# This is safe behind a reverse proxy with IP-based access control
N8N_ORIGIN_CHECK_DISABLED=true

# Disable Python internal mode (not available in Docker)
N8N_RUNNER_COMMAND=/bin/sh
# ── Execution Settings ────────────────────────────────────────────────────
# Execution timeout in seconds (0 = unlimited)
EXECUTIONS_TIMEOUT=3600
EXECUTIONS_TIMEOUT_MAX=7200

# Max number of executions kept in DB
EXECUTIONS_DATA_MAX_AGE=336

# Storage path for binary data (using local filesystem)
N8N_STORAGE_PATH=/home/node/.n8n

# ── SMTP (optional — for email notifications) ────────────────────────────────
# N8N_EMAIL_MODE=smtp
# N8N_SMTP_HOST=smtp.yourdomain.com
# N8N_SMTP_PORT=587
# N8N_SMTP_USER=noreply@yourdomain.com
# N8N_SMTP_PASS=your_smtp_password
# N8N_SMTP_SENDER=noreply@yourdomain.com
# N8N_SMTP_SSL=false

# ── External Secrets (optional) ───────────────────────────────────────────────
# N8N_EXTERNAL_SECRETS_UPDATE_INTERVAL=300
# Protocol must be https to match your domain
N8N_PROTOCOL=https

# WebSocket/Editor URLs must use https and wss
WEBHOOK_URL=https://cuddly-sniffle-4q6556ppgqwhqwjj-5678.app.github.dev/
N8N_EDITOR_BASE_URL=https://cuddly-sniffle-4q6556ppgqwhqwjj-5678.app.github.dev/

# Allow trusted proxies (if behind reverse proxy)
N8N_TRUSTED_PROXY=true