# ============================================================
# Databag Enterprise — Environment Variables
# Copy to .env and fill in real values. NEVER commit .env.
# Generate passwords: openssl rand -base64 32
# ============================================================

# Admin password for Databag web UI
ADMIN_PASSWORD=CHANGE_ME_use_openssl_rand_base64_32

# Ports exposed on the host
HTTP_PORT=8080
# HTTPS_PORT=443

# Resource limits per Databag replica
DATABAG_CPU_LIMIT=2.0
DATABAG_MEM_LIMIT=2G

# Resource limits for Nginx
NGINX_CPU_LIMIT=1.0
NGINX_MEM_LIMIT=512M

# Internal Docker network subnet
NETWORK_SUBNET=172.28.0.0/16
